<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="server"
            type="net.ivpn.core.rest.data.model.Server" />

        <variable
            name="filter"
            type="net.ivpn.core.v2.serverlist.dialog.Filters" />

        <variable
            name="pingstatus"
            type="net.ivpn.core.common.pinger.PingResultFormatter" />

        <variable
            name="navigator"
            type="net.ivpn.core.v2.serverlist.AdapterListener" />

        <variable
            name="forbiddenServer"
            type="net.ivpn.core.rest.data.model.Server" />

        <variable
            name="isFavouritesEntry"
            type="Boolean" />
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/servers_card_background">

        <LinearLayout
            android:id="@+id/server_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:layout_height_dp="@{isFavouritesEntry != null &amp;&amp; isFavouritesEntry ? 48 : 56}"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/server_flag"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="20dp"
                    android:src="@{server}" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/enter_server_description"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:alpha="@{server.canBeUsedAsMultiHopWith(forbiddenServer) ? 1f : 0.6f}"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="-0.03"
                        android:lineSpacingExtra="8sp"
                        android:text="@{isFavouritesEntry != null &amp;&amp; isFavouritesEntry ? server.city : server.getDescription(filter)}"
                        android:textColor="@color/servers_text_color"
                        android:textSize="15sp"
                        android:textStyle="normal" />

                    <FrameLayout
                        android:id="@+id/expand_layout"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/expand_icon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_expand_more"
                            android:alpha="0.6" />

                    </FrameLayout>
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/ipv6_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:background="@drawable/ipv6_text_background"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="2dp"
                    android:text="IPv6"
                    android:textColor="@color/servers_text_color"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical|end">

                    <ImageView
                        android:id="@+id/ping_light"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:src="@{pingstatus.getAppropriateLight}"
                        android:visibility="@{pingstatus.isPingAvailable() ? View.VISIBLE : View.GONE}" />

                    <TextView
                        android:id="@+id/server_ping"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:alpha="0.6"
                        android:fontFamily="sans-serif"
                        android:gravity="end"
                        android:letterSpacing="-0.03"
                        android:lineSpacingExtra="5sp"
                        android:text="@{pingstatus.formatPing}"
                        android:textColor="@color/servers_text_color"
                        android:textSize="15sp"
                        android:textStyle="normal"
                        android:visibility="@{pingstatus.isPingAvailable() ? View.VISIBLE : View.GONE}" />

                </LinearLayout>

                <FrameLayout
                    android:id="@+id/star_layout"
                    android:layout_width="42dp"
                    android:layout_height="match_parent"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/star"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@{server.isFavourite ? @drawable/ic_star_on : @drawable/ic_star_off}" />

                </FrameLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/server_city"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="56dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.03"
                android:text="@{server.country}"
                android:textColor="@color/servers_text_color"
                android:textSize="13sp"
                android:textStyle="normal"
                android:alpha="0.6"
                android:visibility="@{isFavouritesEntry != null &amp;&amp; isFavouritesEntry ? View.VISIBLE : View.GONE}" />
        </LinearLayout>
    </FrameLayout>
</layout>