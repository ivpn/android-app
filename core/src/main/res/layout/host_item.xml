<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="hostItem"
            type="net.ivpn.core.v2.serverlist.items.HostItem" />

        <variable
            name="navigator"
            type="net.ivpn.core.v2.serverlist.AdapterListener" />
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/servers_card_background">

        <LinearLayout
            android:id="@+id/host_layout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="56dp">

            <TextView
                android:id="@+id/host_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.03"
                android:lineSpacingExtra="8sp"
                android:text="@{hostItem.shortHostName}"
                android:textColor="@color/servers_text_color"
                android:textSize="14sp"
                android:textStyle="normal"
                android:alpha="0.8" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:id="@+id/load_indicator"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/host_load"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="-0.03"
                    android:text="@{hostItem.loadPercentage}"
                    android:textColor="@color/servers_text_color"
                    android:textSize="13sp"
                    android:textStyle="normal"
                    android:alpha="0.6" />
            </LinearLayout>

            <View
                android:layout_width="42dp"
                android:layout_height="match_parent" />
        </LinearLayout>
    </FrameLayout>
</layout>

