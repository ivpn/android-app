<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="hostItem"
            type="net.ivpn.core.v2.serverlist.items.HostItem" />

        <variable
            name="navigator"
            type="net.ivpn.core.v2.serverlist.AdapterListener" />

        <variable
            name="isFavouritesEntry"
            type="Boolean" />
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/servers_card_background">

        <LinearLayout
            android:id="@+id/host_layout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/host_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="36dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.03"
                android:lineSpacingExtra="8sp"
                android:text="@{isFavouritesEntry != null &amp;&amp; isFavouritesEntry ? hostItem.displayTitleForFavourites : hostItem.shortHostName}"
                android:textColor="@color/servers_text_color"
                android:textSize="14sp"
                android:textStyle="normal"
                android:alpha="0.8" />

            <TextView
                android:id="@+id/host_load"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.03"
                android:text="@{hostItem.loadPercentage}"
                android:textColor="@color/servers_text_color"
                android:textSize="13sp"
                android:textStyle="normal"
                android:alpha="0.6" />

            <FrameLayout
                android:id="@+id/star_layout"
                android:layout_width="42dp"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true"
                android:visibility="@{hostItem.showFavoriteStar ? View.VISIBLE : View.GONE}">

                <ImageView
                    android:id="@+id/star"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@{hostItem.isFavourite ? @drawable/ic_star_on : @drawable/ic_star_off}" />

            </FrameLayout>

            <View
                android:layout_width="42dp"
                android:layout_height="match_parent"
                android:visibility="@{hostItem.showFavoriteStar ? View.GONE : View.VISIBLE}" />
        </LinearLayout>
    </FrameLayout>
</layout>

